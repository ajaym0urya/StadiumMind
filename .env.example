# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Cloud ─────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── FastAPI Backend ───────────────────────────────────────────────────────────
# Use sqlite for local dev; switch to Cloud SQL PostgreSQL URL for production
DATABASE_URL=sqlite:///./stadium_ops.db
# DATABASE_URL=postgresql://user:password@host:5432/stadiummind
ENVIRONMENT=development

# ── Next.js Frontend ─────────────────────────────────────────────────────────
# Points to the FastAPI backend (localhost in dev, Cloud Run URL in prod)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
