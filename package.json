{
  "name": "electech",
  "version": "1.0.0",
  "description": "ElecTech – Personalized Election Journey Assistant",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && python main.py",
    "client": "cd client && npm run dev",
    "install-all": "cd server && pip install -r requirements.txt && cd ../client && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
